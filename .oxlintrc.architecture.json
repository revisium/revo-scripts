{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import"],
  "rules": {
    "import/no-cycle": ["error", { "ignoreTypes": false }]
  },
  "overrides": [
    {
      "files": ["src/core/spec/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:runtime|registry|host|facade|providers|scripts|testing)(?:/|$)",
                "message": "Core spec must not depend on executable package areas."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/core/registry/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:runtime|host|facade|providers|scripts|testing)(?:/|$)",
                "message": "The registry may depend only on portable spec contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/core/runtime/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:host|facade|providers|scripts|testing)(?:/|$)",
                "message": "Core runtime must remain provider and script neutral."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/host/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:runtime|registry|facade|providers|scripts|testing)(?:/|$)",
                "message": "Host contracts may depend only on portable core spec contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/host/provider-module.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:runtime|registry|facade|providers|scripts|testing)(?:/|$)",
                "message": "Provider module contracts must not depend on execution or concrete scripts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/providers/*/contracts/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:runtime|registry|host|facade|adapters|scripts|testing)(?:/|$)",
                "message": "Provider contracts must remain handler-safe."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/providers/*/adapters/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:runtime|registry|facade|scripts|testing)(?:/|$)",
                "message": "Provider adapters may depend on core spec, host/provider contracts, and their own bounded contracts only."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/scripts/git/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:host|facade|adapters|github|testing)(?:/|$)",
                "message": "Git scripts may depend only on core and handler-safe Git contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["src/scripts/github/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "(?:^|/)(?:host|facade|adapters|git|testing)(?:/|$)",
                "message": "GitHub scripts may depend only on core and handler-safe GitHub contracts."
              }
            ]
          }
        ]
      }
    }
  ]
}
