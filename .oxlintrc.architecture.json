{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import"],
  "rules": {
    "import/no-cycle": ["error", { "ignoreTypes": false }]
  },
  "overrides": [
    {
      "files": ["**/src/index.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^\\./testing(?:/|$)",
                "message": "The production root entrypoint must not expose testing mechanics."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/runtime/spec/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:definition|registry|execution|validation|host|application|providers|scripts|testing)(?:/|$)",
                "message": "Runtime spec is the portable dependency leaf."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/runtime/validation/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:spec|definition|registry|execution|host|application|providers|scripts|testing)(?:/|$)",
                "message": "Runtime validation primitives must remain package-area neutral."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/runtime/definition/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:registry|execution|host|application|providers|scripts|testing)(?:/|$)",
                "message": "Definition may depend only on runtime spec and neutral validation primitives."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/runtime/registry/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:definition|execution|validation|host|application|providers|scripts|testing)(?:/|$)",
                "message": "Registry may depend only on runtime spec contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/runtime/execution/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:definition|host|application|providers|scripts|testing)(?:/|$)",
                "message": "Execution may depend only on runtime spec, registry, and neutral validation primitives."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/runtime/index.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:host|application|providers|scripts|testing)(?:/|$)",
                "message": "The public runtime entrypoint composes provider-neutral runtime areas only."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/host/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:application|providers|scripts|testing|runtime/(?:definition|registry|execution|validation))(?:/|$)",
                "message": "Host ports may depend only on runtime spec contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/providers/*/contracts/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:application|host|adapters|scripts|testing|runtime/(?:definition|registry|execution|validation))(?:/|$)",
                "message": "Provider contracts must remain handler-safe."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/providers/*/adapters/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:application|scripts|testing|runtime/(?:definition|registry|execution|validation))(?:/|$)",
                "message": "Provider adapters may depend on runtime spec, host ports, and their own bounded contracts only."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/scripts/git/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:application|host|testing|runtime/(?:registry|execution|validation)|providers/[^/]+/adapters|providers/github|scripts/github)(?:/|$)",
                "message": "Git scripts may depend only on runtime spec, definition, and handler-safe Git contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/scripts/github/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+(?:application|host|testing|runtime/(?:registry|execution|validation)|providers/[^/]+/adapters|providers/git|scripts/git)(?:/|$)",
                "message": "GitHub scripts may depend only on runtime spec, definition, and handler-safe GitHub contracts."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/src/application/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "regex": "^(?:\\.\\./)+testing(?:/|$)",
                "message": "Production application code must not depend on testing mechanics."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["**/test/integration/consumer/**/*.ts", "**/test/support/consumer/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "**/src/application/**",
                  "**/src/host/bindings/**",
                  "**/src/host/credentials/**",
                  "**/src/host/providers/**",
                  "**/src/host/workspaces/**",
                  "**/src/host/revo-scripts-host.js",
                  "**/src/providers/*/adapters/**",
                  "**/src/providers/*/contracts/**",
                  "**/src/runtime/definition/**",
                  "**/src/runtime/execution/**",
                  "**/src/runtime/registry/**",
                  "**/src/runtime/spec/*/**",
                  "**/src/runtime/validation/**",
                  "**/src/scripts/*/*/**",
                  "**/src/testing/*/**"
                ],
                "message": "Consumer integration tests must use curated package entrypoints instead of private source modules."
              }
            ]
          }
        ]
      }
    }
  ]
}
